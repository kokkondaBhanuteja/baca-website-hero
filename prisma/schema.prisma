// BACA full-stack data model.
// Translatable fields are JSONB "localized text" objects: { en: "...", de?: "...", ... }
// — `en` is always required (enforced in zod on write); other locales are optional and
// fall back to `en` at read time via localizedValue(). Routing/sort/filter keys are kept
// as scalar columns (never queried inside JSONB).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AdminRole {
  ADMIN
  SUPER_ADMIN
}

enum ContentStatus {
  DRAFT
  PUBLISHED
}

enum GalleryMediaType {
  PHOTO
  VIDEO
}

model AdminUser {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  role         AdminRole @default(ADMIN)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("admin_users")
}

model ProductCategory {
  id            String    @id @default(cuid())
  slug          String    @unique
  name          Json // LocalizedText
  description   Json? // LocalizedText
  imageUrl      String?
  imagePublicId String?
  sortOrder     Int       @default(0)
  isPublished   Boolean   @default(true)
  products      Product[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([sortOrder])
  @@map("product_categories")
}

model Product {
  id            String          @id @default(cuid())
  slug          String          @unique
  name          Json // LocalizedText
  summary       Json? // LocalizedText (short "Cardamom · Pepper …" line)
  description   Json? // LocalizedText (long copy)
  botanicalName String? // Latin name, italic subtitle (e.g. "Elettaria cardamomum")
  originRegions Json? // string[] — region pills, e.g. ["Coorg, Kerala", …]
  specs         Json? // { label, value }[] — specifications key/value grid
  harvestMonths Json? // number[] (1–12) — seasonality calendar light highlight
  peakMonths    Json? // number[] (1–12) — seasonality calendar peak highlight
  imageUrl      String? // cover (synced from images[0]) — used on cards / grid / SEO
  imagePublicId String?
  images        Json? // { url, publicId }[] — gallery shown as a carousel on the detail page
  categoryId    String
  category      ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  sortOrder     Int             @default(0)
  isPublished   Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([categoryId, sortOrder])
  @@map("products")
}

model BlogType {
  id          String        @id @default(cuid())
  slug        String        @unique
  name        Json // LocalizedText
  sortOrder   Int           @default(0)
  isPublished Boolean       @default(true)
  articles    BlogArticle[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([sortOrder])
  @@map("blog_types")
}

model BlogArticle {
  id                   String        @id @default(cuid())
  slug                 String        @unique
  blogTypeId           String
  blogType             BlogType      @relation(fields: [blogTypeId], references: [id], onDelete: Restrict)
  title                Json // LocalizedText
  excerpt              Json // LocalizedText
  body                 Json // LocalizedText (rich text per locale; en filled, others optional)
  coverImageUrl        String?
  coverImagePublicId   String?
  authorName           String? // byline name (proper noun — scalar, falls back to "BACA Team")
  authorRole           String? // byline role/title (scalar)
  authorAvatarUrl      String? // Cloudinary avatar (delivery URL)
  authorAvatarPublicId String? // Cloudinary id for transform/delete
  readMinutes          Int           @default(3)
  status               ContentStatus @default(DRAFT)
  featured             Boolean       @default(false)
  publishedAt          DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@index([status, publishedAt])
  @@index([blogTypeId])
  @@map("blog_articles")
}

model GalleryImage {
  id            String           @id @default(cuid())
  caption       Json? // LocalizedText
  imageUrl      String
  imagePublicId String
  mediaType     GalleryMediaType @default(PHOTO)
  sortOrder     Int              @default(0)
  isPublished   Boolean          @default(true)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([sortOrder])
  @@map("gallery_images")
}

