# Copy to .env and fill in. Never commit real secrets.
# Generate JWT_SECRET with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"

DATABASE_URL="postgresql://USER@localhost:5432/baca_dev?schema=public"

JWT_SECRET=""
SEED_ADMIN_EMAIL="admin@baca.local"
SEED_ADMIN_PASSWORD="set-a-strong-password"

CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""

# SMTP (for the public enquiry form → email notification).
# All five must be set for the email to send; otherwise the form still works
# and the enquiry is stored in the DB, but the email step is skipped.
# Typical hosts: smtp.gmail.com:587, smtp-mail.outlook.com:587, smtp.sendgrid.net:587, smtp.resend.com:465
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="BACA <noreply@baca.example>"
ENQUIRY_NOTIFY_TO="trade@baca.example"
